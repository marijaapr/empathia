# Empathia - Environment Variables Configuration

# ============ SUPABASE CONFIGURATION ============
# Get these from your Supabase project settings

# Your Supabase project URL
# Found at: Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public key for frontend)
# Found at: Project Settings → API → anon key
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (private key for backend)
# Found at: Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============ OPENAI CONFIGURATION ============
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============ FLASK CONFIGURATION ============
# Secret key for Flask sessions (use a strong random value)
SECRET_KEY=your-secret-key-change-this-in-production

# Port to run the server on (default: 5000)
PORT=5001

# Debug mode (set to True for development, False for production)
FLASK_DEBUG=True
